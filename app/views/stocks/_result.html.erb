<%= render 'layouts/messages' %>

<% if @stock %>
  <div class="card card-header d-inline pt-3">
    <strong>Symbol: </strong> <%= @stock.ticker %>
    <strong>Name: </strong> <%= @stock.name %>
    <strong>Price: </strong> <%= @stock.last_price %>
    <% if current_user.can_track_stock?(@stock.ticker) %>
      <%= link_to 'Add to porfolio', user_stocks_path(user: current_user, ticker: @stock.ticker), class: 'btn btn-dark', method: :post %>
    <% else %>
      <p class="badge badge-secondary">You are already tracking
        <% if !current_user.under_stock_limit? %>
          10 stocks
        <% end %>

        <% if current_user.stock_already_tracked?(@stock.ticker) %>
          this stock
        <% end %>
      </p>
    <% end %>
  </div>
<% end %>
