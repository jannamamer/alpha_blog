<h1>Stocks</h1>

<div class="pb-3 pl-3 row">
  <h3>Search</h3>
  <div class="w-100"></div>

  <%= form_tag search_stock_path, remote: true, method: :get, class: 'form-inline' do %>
    <div class="form-group row">
      <div class="col-10">
        <%= text_field_tag :stock, params[:stock], class: 'form-control mr-sm-2', placeholder: 'Stock ticker symbol', aria_label: 'Search' %>
      </div>
      <div class="col-2 pl-0">
        <%= button_tag type: :submit, class: 'btn btn-outline-dark' do %>
          <%= fa_icon 'search' %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<div id="search-result" class="pl-3 row">
</div>

<table class="table">
  <thead>
    <tr>
      <th scope="col">Ticker</th>
      <th scope="col">Name</th>
      <th scope="col">Price</th>
      <th scope="col">Actions</th>
    </tr>
  </thead>
  <tbody>
    <%= render partial: 'stocks/stock', collection: @tracked_stocks, as: :stock %>
  </tbody>
</table>
