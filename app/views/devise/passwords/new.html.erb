<h1><%= t('.forgot_your_password') %></h1>

<div class="row justify-content-center">
  <div class="col-12 mt-4">
    <%= form_with(model: resource, as: resource_name, url: password_path(resource_name), class: "shadow p-3 mb-3 bg-success rounded", html: { method: :post }, local: true) do |f| %>
      <%= bootstrap_devise_error_messages! %>

      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= f.submit t('.send_me_reset_password_instructions'), class: 'btn btn-outline-light btn-lg' %>
      </div>
    <% end %>

    <%= render 'devise/shared/links' %>
  </div>
</div>
