<div class="card">
  <div class="card-body">
    <h4><%= t('.title', resource: resource_name.to_s.humanize) %></h4>

    <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), local: true) do |f| %>
      <%= bootstrap_devise_error_messages! %>
      <div class="form-group row">
        <div class="col">
          <%= f.text_field :first_name, class: "form-control shadow rounded", placeholder: "First name" %>
        </div>
        <div class="w-100 d-md-none d-block pb-3"></div>
        <div class="col">
          <%= f.text_field :last_name, class: "form-control shadow rounded", placeholder: "Last name" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col">
          <%= f.text_field :username, class: "form-control shadow rounded", placeholder: "Username" %>
        </div>
        <div class="w-100 d-md-none d-block pb-3"></div>
        <div class="col">
          <%= f.email_field :email, class: "form-control shadow rounded", placeholder: "Email" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col">
          <%= f.password_field :current_password, class: "form-control shadow rounded", placeholder: "Current password" %>
          <small class="form-text"><%= t('.we_need_your_current_password_to_confirm_your_changes') %></small>
        </div>
      </div>

      <div class="form-group row">
        <div class="col">
          <%= f.password_field :password, class: "form-control shadow rounded", placeholder: "New Password" %>

          <% if @minimum_password_length %>
            <small class="form-text"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></small>
          <% end %>
        </div>
        <div class="w-100 d-md-none d-block pb-3"></div>
        <div class="col">
          <%= f.password_field :password_confirmation, class: "form-control shadow rounded", placeholder: "New Password confirmation" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col">
          <%= link_to t('.cancel_my_account'), registration_path(resource_name), data: { confirm: t('.are_you_sure') }, method: :delete %>
          <%= link_to t('.back'), :back %>
        </div>
        <div class="col">
          <%= f.submit t('.update'), class: 'btn btn-outline-dark btn-lg float-right' %>
        </div>
      </div>
    <% end %>

  </div>
</div>
