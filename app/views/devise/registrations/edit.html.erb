<h1><%= t('.title', resource: resource_name.to_s.humanize) %></h1>

<div class="row justify-content-center">
  <div class="col-12 mt-4">
    <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), class: "shadow p-3 mb-3 bg-success rounded", local: true, html: { method: :put }) do |f| %>
      <%= bootstrap_devise_error_messages! %>
      <div class="form-group row justify-content-center">
        <%= image_tag resource.image.url, alt: 'Profile Picture', class: "img-thumbnail" %>
      </div>
      <div class="form-group row">
        <div class="col-2">
          <%= f.label :image, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.file_field :image, autofocus: true, class: "form-control shadow rounded" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :email, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.email_field :email, class: "form-control shadow rounded", placeholder: "Enter a email" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :first_name, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.text_field :first_name, class: "form-control shadow rounded", placeholder: "Enter a first name" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :last_name, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.text_field :last_name, class: "form-control shadow rounded", placeholder: "Enter a last name" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :gender, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.select :gender, options_from_collection_for_select(LookUp.where(group: "gender"), :id, :name), { :include_blank => "Select Gender" }, { :class => "form-control shadow rounded"} %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :username, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.text_field :username, autofocus: true, class: "form-control shadow rounded", placeholder: "Enter a username" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :password, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.password_field :password, class: "form-control shadow rounded", placeholder: "Enter a password" %>

          <small class="form-text text-white"><%= t('.leave_black_if_you_don_t_want_to_change_it') %></small>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :password_confirmation, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.password_field :password_confirmation, class: "form-control shadow rounded", placeholder: "Enter a password confirmation" %>
        </div>
      </div>

      <div class="form-group row">
        <div class="col-2">
          <%= f.label :current_password, class: "col-form-label" %>
        </div>
        <div class="col-10">
          <%= f.password_field :current_password, class: "form-control shadow rounded", placeholder: "Enter a current password" %>

          <small class="form-text text-white"><%= t('.we_need_your_current_password_to_confirm_your_changes') %></small>
        </div>
      </div>

      <div class="form-group row justify-content-center">
        <%= f.submit t('.update'), class: 'btn btn-outline-light btn-lg' %>
      </div>
    <% end %>

    <p><%= t('.unhappy') %>? <%= link_to t('.cancel_my_account'), registration_path(resource_name), data: { confirm: t('.are_you_sure') }, method: :delete %>.</p>

    <%= link_to t('.back'), :back %>
  </div>
</div>
